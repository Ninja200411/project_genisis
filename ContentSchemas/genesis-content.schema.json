{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-genesis.invalid/schemas/genesis-content-v1.json",
  "title": "Project Genesis Content Definitions",
  "oneOf": [
    { "$ref": "#/$defs/building" },
    { "$ref": "#/$defs/resource" },
    { "$ref": "#/$defs/personRole" },
    { "$ref": "#/$defs/vehicle" },
    { "$ref": "#/$defs/recipe" },
    { "$ref": "#/$defs/technology" }
  ],
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaMajor", "schemaMinor", "displayName"],
      "properties": {
        "schemaMajor": { "const": 1 },
        "schemaMinor": { "type": "integer", "minimum": 0 },
        "displayName": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "default": "" },
        "tags": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" }, "default": [] }
      }
    },
    "quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": { "type": "number", "minimum": 0 },
        "unit": { "enum": ["kg", "m3", "J", "W", "s", "credit"] }
      }
    },
    "resourceAmount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resource", "amount"],
      "properties": {
        "resource": { "type": "string", "pattern": "^resource:[a-z0-9][a-z0-9._-]*$" },
        "amount": { "$ref": "#/$defs/quantity" }
      }
    },
    "building": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "constructionCost", "constructionTime", "powerDemand"],
      "properties": {
        "type": { "const": "building" },
        "id": { "type": "string", "pattern": "^building:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "constructionCost": { "type": "array", "items": { "$ref": "#/$defs/resourceAmount" }, "minItems": 1 },
        "constructionTime": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "s" } } }] },
        "powerDemand": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "W" } } }] },
        "requiredTechnologies": { "type": "array", "items": { "type": "string", "pattern": "^technology:[a-z0-9][a-z0-9._-]*$" }, "default": [] }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "storageUnit", "unitMass", "unitVolume"],
      "properties": {
        "type": { "const": "resource" },
        "id": { "type": "string", "pattern": "^resource:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "storageUnit": { "enum": ["kg", "m3", "J"] },
        "unitMass": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "kg" } } }] },
        "unitVolume": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "m3" } } }] }
      }
    },
    "personRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "wagePerSecond"],
      "properties": {
        "type": { "const": "personRole" },
        "id": { "type": "string", "pattern": "^role:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "wagePerSecond": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "credit" } } }] },
        "requiredTechnologies": { "type": "array", "items": { "type": "string", "pattern": "^technology:[a-z0-9][a-z0-9._-]*$" }, "default": [] }
      }
    },
    "vehicle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "cargoMass", "cargoVolume", "powerDemand"],
      "properties": {
        "type": { "const": "vehicle" },
        "id": { "type": "string", "pattern": "^vehicle:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "cargoMass": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "kg" } } }] },
        "cargoVolume": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "m3" } } }] },
        "powerDemand": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "W" } } }] }
      }
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "inputs", "outputs", "duration", "supportedBuildings"],
      "properties": {
        "type": { "const": "recipe" },
        "id": { "type": "string", "pattern": "^recipe:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "inputs": { "type": "array", "items": { "$ref": "#/$defs/resourceAmount" } },
        "outputs": { "type": "array", "items": { "$ref": "#/$defs/resourceAmount" }, "minItems": 1 },
        "duration": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "value": { "exclusiveMinimum": 0 }, "unit": { "const": "s" } } }] },
        "supportedBuildings": { "type": "array", "items": { "type": "string", "pattern": "^building:[a-z0-9][a-z0-9._-]*$" }, "minItems": 1 }
      }
    },
    "technology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id", "metadata", "researchCost", "researchTime"],
      "properties": {
        "type": { "const": "technology" },
        "id": { "type": "string", "pattern": "^technology:[a-z0-9][a-z0-9._-]*$" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "researchCost": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "credit" } } }] },
        "researchTime": { "allOf": [{ "$ref": "#/$defs/quantity" }, { "properties": { "unit": { "const": "s" } } }] },
        "prerequisites": { "type": "array", "items": { "type": "string", "pattern": "^technology:[a-z0-9][a-z0-9._-]*$" }, "default": [] }
      }
    }
  }
}
