{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Genesis: Generate VS Code files",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/Scripts/setup/generate-vscode.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Genesis: Build Editor",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/Scripts/build/build-editor.ps1"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}
